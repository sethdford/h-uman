#!/bin/sh
# pre-commit: basic checks on C source files.
# Activate: git config core.hooksPath .githooks

if [ -d "src" ] && [ -f "CMakeLists.txt" ]; then
    staged_c=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.[ch]$')
    if [ -n "$staged_c" ]; then
        for f in $staged_c; do
            if grep -qn '	' "$f" 2>/dev/null; then
                echo "Warning: tabs found in $f (project uses spaces)"
            fi
        done
    fi
fi
