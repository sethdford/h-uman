{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "com.seaclaw.platform": "all",
    "com.seaclaw.version": "0.3.0"
  },
  "$description": "Liquid Glass tokens — three tiers of glass depth inspired by Apple visionOS Liquid Glass, adapted for web/native",
  "glass": {
    "subtle": {
      "blur": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Lightest frosted glass"
      },
      "saturate": {
        "$value": "120%",
        "$type": "string",
        "$description": "Low saturation boost"
      },
      "bg-opacity": {
        "$value": 0.04,
        "$type": "number",
        "$description": "Nearly transparent"
      },
      "border-opacity": {
        "$value": 0.05,
        "$type": "number",
        "$description": "Barely visible border"
      },
      "inset-opacity": {
        "$value": 0,
        "$type": "number",
        "$description": "No inset highlight"
      },
      "tint-opacity": {
        "$value": 0.02,
        "$type": "number",
        "$description": "Minimal environment tint"
      },
      "refraction-scale": {
        "$value": 0,
        "$type": "number",
        "$description": "No refraction at subtle tier"
      },
      "$description": "Backgrounds, nav chrome, ambient panels — z.raised (100)"
    },
    "standard": {
      "blur": {
        "$value": "24px",
        "$type": "dimension",
        "$description": "Standard frosted glass"
      },
      "saturate": {
        "$value": "180%",
        "$type": "string",
        "$description": "Moderate saturation boost"
      },
      "bg-opacity": {
        "$value": 0.06,
        "$type": "number",
        "$description": "Slightly visible"
      },
      "border-opacity": {
        "$value": 0.08,
        "$type": "number",
        "$description": "Subtle border"
      },
      "inset-opacity": {
        "$value": 0.06,
        "$type": "number",
        "$description": "Subtle top highlight"
      },
      "tint-opacity": {
        "$value": 0.04,
        "$type": "number",
        "$description": "Subtle environment tint"
      },
      "refraction-scale": {
        "$value": 2,
        "$type": "number",
        "$description": "Light refraction distortion"
      },
      "$description": "Cards, panels, interactive surfaces — z.dropdown (1000)"
    },
    "prominent": {
      "blur": {
        "$value": "32px",
        "$type": "dimension",
        "$description": "Heavy frosted glass with refraction"
      },
      "saturate": {
        "$value": "200%",
        "$type": "string",
        "$description": "Strong saturation boost"
      },
      "bg-opacity": {
        "$value": 0.08,
        "$type": "number",
        "$description": "More visible"
      },
      "border-opacity": {
        "$value": 0.12,
        "$type": "number",
        "$description": "Visible chromatic border"
      },
      "inset-opacity": {
        "$value": 0.1,
        "$type": "number",
        "$description": "Strong top highlight"
      },
      "tint-opacity": {
        "$value": 0.06,
        "$type": "number",
        "$description": "Noticeable environment tint"
      },
      "refraction-scale": {
        "$value": 3,
        "$type": "number",
        "$description": "Visible refraction distortion"
      },
      "$description": "Modals, sheets, hero elements, overlays — z.modal (1300)"
    }
  }
}
